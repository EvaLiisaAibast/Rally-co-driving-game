# Rally Pacenote Academy - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# FEEDBACK EMAIL CONFIGURATION
# Set these to receive player feedback via email
# ============================================

# Creator email address where feedback will be sent
CREATOR_EMAIL=aevaliisa@gmail.com

# SMTP server settings (for sending feedback emails)
# Examples:
# Gmail: smtp.gmail.com, Outlook: smtp.office365.com, Yahoo: smtp.mail.yahoo.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# REDIS CONFIGURATION (for multiplayer scaling)
# ============================================

# Redis URL for multi-server support (optional for local/LAN play)
REDIS_URL=redis://localhost:6379

# ============================================
# SMTP ENCRYPTION KEY (auto-generated if not set)
# ============================================

# Optional: Set a fixed key for encrypting player email passwords
# If not set, a random key will be generated on each server start
SMTP_KEY=

# ============================================
# SERVER CONFIGURATION
# ============================================

# Port to run the server on (default: 3000)
PORT=3000
